ENV['RCT_NEW_ARCH_ENABLED'] = '1'

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'AdgeistExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )


  # Run Codegen during development for the example app.
  pre_install do |installer|
    system("cd ../../ && npx bob build --target codegen")
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # fmt 11.0.2 (pinned by React Native) auto-detects consteval support from
    # the Apple Clang version and assumes any Clang >= 14 has it working, but
    # it's still broken with this newer Clang - format strings that should be
    # compile-time-checked fail with "is not a constant expression". Force
    # fmt's own non-consteval fallback path instead of patching its source.
    # Applied to EVERY pod target (not just 'fmt'): folly and many React-*
    # targets include fmt headers and hit the same error; the define is a
    # no-op for targets that never include fmt.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        defs = Array(config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || '$(inherited)')
        defs << 'FMT_USE_CONSTEVAL=0' unless defs.include?('FMT_USE_CONSTEVAL=0')
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs
      end
    end

    # fmt 11.0.2's detection chain unconditionally #defines FMT_USE_CONSTEVAL,
    # stomping the -D flag above (newer fmt versions start the chain with
    # `#ifdef FMT_USE_CONSTEVAL` to respect an external value). Patch that one
    # guard so the flag takes effect; re-applied automatically on every
    # pod install since the vendored file gets restored.
    fmt_base_h = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base_h)
      original = "#if !defined(__cpp_lib_is_constant_evaluated)\n#  define FMT_USE_CONSTEVAL 0"
      patched  = "#if defined(FMT_USE_CONSTEVAL)\n// Respect the externally provided FMT_USE_CONSTEVAL (patched by Podfile)\n#elif !defined(__cpp_lib_is_constant_evaluated)\n#  define FMT_USE_CONSTEVAL 0"
      content = File.read(fmt_base_h)
      if content.include?(original) && !content.include?('patched by Podfile')
        File.chmod(0644, fmt_base_h) # pod sources are checked out read-only
        File.write(fmt_base_h, content.sub(original, patched))
        Pod::UI.puts 'Patched fmt/base.h to respect FMT_USE_CONSTEVAL=0'.green
      end
    end
  end
end
